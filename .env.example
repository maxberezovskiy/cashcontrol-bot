# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-your-bot-token

# URL backend API (в docker-compose: http://backend:8000/api/v1)
BACKEND_URL=http://backend:8000/api/v1

# Общий секрет с backend (должен совпадать с BOT_API_SECRET в backend/.env)
BOT_API_SECRET=change-me-to-a-random-bot-secret

# Имя бота без @ (опционально, для deep-link подсказок)
BOT_USERNAME=cashcontrol_bot
